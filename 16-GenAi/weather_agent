import os
import json
import time
import re
import requests
from dotenv import load_dotenv
from google import genai
from google.genai import types

# -----------------------------
# LOAD ENV
# -----------------------------
load_dotenv()

client = genai.Client(api_key=os.getenv("API_KEY"))

# -----------------------------
# WEATHER API
# -----------------------------
API_URL = "https://api.openweathermap.org/data/2.5/weather"
WEATHER_API_KEY = "f668351e5606b81d754b29f3fe0bdce3"

# -----------------------------
# EXTRACT JSON FUNCTION
# -----------------------------
def extract_json(text):
    match = re.search(r'\{.*?\}', text, re.DOTALL)
    if match:
        return json.loads(match.group())
    else:
        raise ValueError("No JSON found in response")


# -----------------------------
# WEATHER TOOL
# -----------------------------
def get_weather(city, unit="celsius"):

    units = "metric"

    if unit.lower() == "fahrenheit":
        units = "imperial"

    params = {
        "q": city,
        "appid": WEATHER_API_KEY,
        "units": units
    }

    response = requests.get(API_URL, params=params)
    data = response.json()

    if response.status_code != 200:
        return "Weather data not found."

    temp = data["main"]["temp"]
    desc = data["weather"][0]["description"]

    if units == "metric":
        return f"{temp}°C with {desc}"
    else:
        return f"{temp}°F with {desc}"


# -----------------------------
# TOOL REGISTRY
# -----------------------------
available_tools = {
    "get_weather": get_weather
}

# -----------------------------
# SYSTEM PROMPT
# -----------------------------
system_prompt = """
You are an AI assistant that uses tools.

Steps you follow:

1 plan
2 action
3 output

Rules:

- Default temperature unit is Celsius.
- Use Fahrenheit only if the user explicitly asks.
- Always return ONLY ONE JSON object.

JSON format:

{
 "step":"plan | action | output",
 "content":"explanation",
 "function":"tool name",
 "input":{"city":"city name","unit":"celsius"}
}

Example:

User: weather in Mumbai

{"step":"plan","content":"User wants weather of Mumbai"}
{"step":"action","function":"get_weather","input":{"city":"Mumbai","unit":"celsius"}}
{"step":"output","content":"Weather in Mumbai is 30°C"}
"""

# -----------------------------
# CONTINUOUS CHAT
# -----------------------------
while True:

    user_query = input("\nUser: ")

    if user_query.lower() in ["exit", "quit"]:
        print("Agent stopped.")
        break

    current_input = user_query

    while True:

        response = client.models.generate_content(
            model="gemini-2.5-flash",
            contents=current_input,
            config=types.GenerateContentConfig(
                system_instruction=system_prompt,
                response_mime_type="application/json"
            )
        )

        parsed_output = extract_json(response.text)

        step = parsed_output.get("step")

        # -----------------------------
        # PLAN
        # -----------------------------
        if step == "plan":

            print("🧠 PLAN:", parsed_output["content"])

            current_input = parsed_output["content"]

        # -----------------------------
        # ACTION
        # -----------------------------
        elif step == "action":

            tool = parsed_output["function"]
            tool_input = parsed_output["input"]

            city = tool_input.get("city")
            unit = tool_input.get("unit", "celsius")

            print("⚙️ ACTION:", tool, city, unit)

            if tool in available_tools:

                result = available_tools[tool](city, unit)

                print("👀 OBSERVE:", result)

                current_input = f"Observation: {result}"

        # -----------------------------
        # OUTPUT
        # -----------------------------
        elif step == "output":

            print("🤖 AI:", parsed_output["content"])

            break

        time.sleep(2)